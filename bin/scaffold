  ['help', 'help'],
  ['yes', '--yes'],
  ['-y', '--yes'],
  ['--yes', '--yes'],
  ['dry-run', '--dry-run'],
  ['--dry-run', '--dry-run'],
  ['profile', '--profile'],
  ['--profile', '--profile'],
  ['package-manager', '--package-manager'],
  ['--package-manager', '--package-manager'],
