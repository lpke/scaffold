const isHelpFlag = (arg) => arg === '-h' || arg === '--help';

const usage = () => {
  console.log(`Usage: scaffold [dir] [options]
       scaffold help [topic]

Scaffold a new Node project or apply Luke-style defaults to an existing one.

Commands:
  help [topic]                  Show top-level help or detailed flag help

Options:
  -y, --yes                     Use defaults without prompts
  --dry-run                     Print planned changes only
  --profile <name>              config, node, node-vitest, vite-react
  --package-manager <name>      pnpm, yarn, npm, keep
  --node <major>                24, 22, 20, 18, 16
  --strict                      Make tsconfig strict
  --non-strict                  Make tsconfig non-strict
  --preserve-ts                 Leave existing tsconfig compiler strictness alone
  --tailwind-prettier           Write prettier.config.mjs with tailwind plugin
  --force                       Overwrite starter files if they already exist
  --no-backup                   Do not create *.scaffold-backup files
  --direnv / --no-direnv        Run or skip direnv allow
  --flake-lock / --no-flake-lock
  --install / --no-install      Run or skip package manager install
  --git-add / --no-git-add      Run or skip git add -N for new flake files
  -h, --help                    Show help

Help:
  scaffold help                 Show this help
  scaffold help --profile       Show help for --profile
  scaffold --profile --help     Show help for --profile`);
};

