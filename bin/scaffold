  ['--git-add', '--git-add'],
  ['no-git-add', '--git-add'],
  ['--no-git-add', '--git-add'],
]);

const helpTopicFor = (topic) => {
  const key = HELP_TOPIC_ALIASES.get(topic);
  if (!key) {
    throw new Error(`Unknown help topic: ${topic}`);
  }
  return key;
};

const printHelpTopic = (topic) => {
  console.log(HELP_TOPICS[helpTopicFor(topic)]);
};

const inlineHelpTopic = (argv) => {
  const topics = argv.filter(
    (arg) => !isHelpFlag(arg) && HELP_TOPIC_ALIASES.has(arg),
  );
  if (topics.length === 1) {
    return topics[0];
  }

  for (let index = 0; index < argv.length; index += 1) {
    if (!isHelpFlag(argv[index])) {
      continue;
    }
    for (const candidate of [argv[index - 1], argv[index + 1]]) {
      if (candidate && HELP_TOPIC_ALIASES.has(candidate)) {
        return candidate;
      }
    }
  }

  return null;
};

const printRequestedHelp = (argv) => {
  if (argv.length === 0) {
    usage();
    return true;
  }

  if (argv[0] === 'help') {
    const topics = argv.slice(1).filter((arg) => !isHelpFlag(arg));
    if (topics.length === 0) {
      if (argv.slice(1).some(isHelpFlag)) {
        printHelpTopic('help');
      } else {
        usage();
      }
      return true;
    }
    if (topics.length > 1) {
      throw new Error('Usage: scaffold help [topic]');
    }
    printHelpTopic(topics[0]);
    return true;
  }

  if (argv.some(isHelpFlag)) {
    const topic = inlineHelpTopic(argv);
    if (topic) {
      printHelpTopic(topic);
    } else {
      usage();
    }
    return true;
  }

  return false;
};

const parseArgs = (argv) => {
  const opts = {
    dir: null,
    yes: false,
    dryRun: false,
    force: false,
    backup: true,
    gitAdd: true,
    direnv: undefined,
    flakeLock: undefined,
    install: undefined,
    profile: null,
    packageManager: null,
    nodeMajor: null,
    tsMode: null,
    tailwindPrettier: false,
  };

  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];
    const nextValue = () => {
      const value = argv[index + 1];
      if (!value || value.startsWith('-')) {
        throw new Error(`Missing value for ${arg}`);
      }
      index += 1;
      return value;
    };

    switch (arg) {
      case '-h':
      case '--help':
        opts.help = true;
        break;
      case '-y':
      case '--yes':
        opts.yes = true;
        break;
      case '--dry-run':
        opts.dryRun = true;
        break;
      case '--force':
        opts.force = true;
        break;
      case '--no-backup':
        opts.backup = false;
        break;
      case '--direnv':
        opts.direnv = true;
        break;
      case '--no-direnv':
        opts.direnv = false;
        break;
      case '--flake-lock':
        opts.flakeLock = true;
        break;
      case '--no-flake-lock':
        opts.flakeLock = false;
        break;
      case '--install':
        opts.install = true;
        break;
      case '--no-install':
        opts.install = false;
        break;
      case '--git-add':
        opts.gitAdd = true;
        break;
      case '--no-git-add':
        opts.gitAdd = false;
        break;
      case '--strict':
        opts.tsMode = 'strict';
        break;
      case '--non-strict':
        opts.tsMode = 'non-strict';
        break;
      case '--preserve-ts':
        opts.tsMode = 'preserve';
        break;
      case '--tailwind-prettier':
        opts.tailwindPrettier = true;
        break;
      case '--profile':
        opts.profile = nextValue();
        break;
      case '--package-manager':
        opts.packageManager = nextValue();
        break;
      case '--node':
        opts.nodeMajor = nextValue();
        break;
      default:
        if (arg.startsWith('-')) {
          throw new Error(`Unknown option: ${arg}`);
        }
        if (opts.dir) {
          throw new Error(`Unexpected extra argument: ${arg}`);
        }
        opts.dir = arg;
    }
  }

  return opts;
};

const statOrNull = async (filePath) => {
  try {
    return await fsp.stat(filePath);
  } catch (error) {
    if (error.code === 'ENOENT') {
      return null;
    }
    throw error;
  }
};

const fileExists = async (filePath) => Boolean(await statOrNull(filePath));

const readText = async (filePath) => fsp.readFile(filePath, 'utf8');

const commandVersion = (command, fallback) => {
  const result = cp.spawnSync(command, ['--version'], {
    encoding: 'utf8',
    stdio: ['ignore', 'pipe', 'ignore'],
  });
  const version = result.status === 0 ? result.stdout.trim().split(/\s+/)[0] : '';
  return version || fallback;
};

const findTemplateRoot = async () => {
  const scriptDir = __dirname;
  const candidates = [
    path.resolve(scriptDir, '../share/scaffold/templates'),
    path.join(os.homedir(), '.local/share/scaffold/templates'),
  ];

  for (const candidate of candidates) {
    if (
      (await fileExists(path.join(candidate, 'common/.editorconfig'))) ||
      (await fileExists(path.join(candidate, 'common/dot_editorconfig')))
    ) {
      return candidate;
    }
  }

  throw new Error(
    `Could not find scaffold templates. Checked: ${candidates.join(', ')}`,
  );
};

const sourceTemplatePath = (templateRoot, relativePath) => {
  const installedPath = path.join(templateRoot, relativePath);
  if (fs.existsSync(installedPath)) {
    return installedPath;
  }

  const sourceRelativePath = relativePath
    .split('/')
    .map((part) => (part.startsWith('.') ? `dot_${part.slice(1)}` : part))
    .join('/');
  return path.join(templateRoot, sourceRelativePath);
};

const readTemplate = async (templateRoot, relativePath) =>
  readText(sourceTemplatePath(templateRoot, relativePath));

const sanitizePackageName = (dirPath) => {
  const name = path.basename(path.resolve(dirPath));
  return (
    name
      .toLowerCase()
      .replace(/[^a-z0-9._-]+/g, '-')
      .replace(/^-+|-+$/g, '') || 'node-app'
  );
};

const stripJsonComments = (source) => {
  let output = '';
  let inString = false;
  let quote = '';
  let escaped = false;

  for (let index = 0; index < source.length; index += 1) {
    const char = source[index];
    const next = source[index + 1];

    if (inString) {
      output += char;
      escaped = !escaped && char === '\\';
      if (!escaped && char === quote) {
        inString = false;
        quote = '';
      } else if (char !== '\\') {
        escaped = false;
      }
      continue;
    }

    if (char === '"' || char === "'") {
      inString = true;
      quote = char;
      output += char;
      continue;
    }

    if (char === '/' && next === '/') {
      while (index < source.length && source[index] !== '\n') {
        index += 1;
      }
      output += '\n';
      continue;
    }

    if (char === '/' && next === '*') {
      index += 2;
      while (
        index < source.length &&
        !(source[index] === '*' && source[index + 1] === '/')
      ) {
        index += 1;
      }
      index += 1;
      continue;
    }

    output += char;
  }

  return output.replace(/,\s*([}\]])/g, '$1');
};

const readJson = async (filePath) => {
  const source = await readText(filePath);
  return JSON.parse(stripJsonComments(source));
};

class Workspace {
  constructor({ targetDir, dryRun, backup }) {
    this.targetDir = targetDir;
    this.dryRun = dryRun;
    this.backup = backup;
    this.changed = [];
    this.skipped = [];
  }

  targetPath(relativePath) {
    return path.join(this.targetDir, relativePath);
  }

  async backupFile(filePath) {
    if (!this.backup || this.dryRun || !(await fileExists(filePath))) {
      return;
    }

    const backupPath = `${filePath}.scaffold-backup`;
    if (!(await fileExists(backupPath))) {
      await fsp.copyFile(filePath, backupPath);
    }
  }

  async write(relativePath, content, { overwrite = true } = {}) {
    const filePath = this.targetPath(relativePath);
    const exists = await fileExists(filePath);

    if (exists) {
      const current = await readText(filePath);
      if (current === content) {
        this.skipped.push(`${relativePath} unchanged`);
        return;
      }
      if (!overwrite) {
        this.skipped.push(`${relativePath} exists`);
        return;
      }
      await this.backupFile(filePath);
    }

    this.changed.push(`${exists ? 'updated' : 'created'} ${relativePath}`);
    if (this.dryRun) {
      return;
    }

    await fsp.mkdir(path.dirname(filePath), { recursive: true });
    await fsp.writeFile(filePath, content);
  }

  async mergeLines(relativePath, lines) {
    const filePath = this.targetPath(relativePath);
    const exists = await fileExists(filePath);
    const current = exists ? await readText(filePath) : '';
    const existingLines = new Set(
      current
        .split(/\r?\n/)
        .map((line) => line.trim())
        .filter(Boolean),
    );
    const missing = lines.filter((line) => !existingLines.has(line.trim()));

    if (missing.length === 0) {
      this.skipped.push(`${relativePath} already has defaults`);
      return;
    }

    if (exists) {
      await this.backupFile(filePath);
    }

    const prefix = current && !current.endsWith('\n') ? '\n' : '';
    const content = exists
      ? `${current}${prefix}${missing.join('\n')}\n`
      : `${missing.join('\n')}\n`;

    this.changed.push(
      `${exists ? 'merged' : 'created'} ${relativePath} (${missing.length} lines)`,
    );
    if (!this.dryRun) {
      await fsp.mkdir(path.dirname(filePath), { recursive: true });
      await fsp.writeFile(filePath, content);
    }
  }
}

const promptChoice = async (rl, message, choices, defaultValue) => {
  const labels = choices
    .map((choice, index) => {
      const suffix = choice.value === defaultValue ? ' default' : '';
      return `${index + 1}. ${choice.label}${suffix}`;
    })
    .join('\n');

  while (true) {
    const answer = (
      await rl.question(`${message}\n${labels}\n> `)
    ).trim();
    if (!answer) {
      return defaultValue;
    }
    const byNumber = Number(answer);
    if (Number.isInteger(byNumber) && choices[byNumber - 1]) {
      return choices[byNumber - 1].value;
    }
    const byValue = choices.find((choice) => choice.value === answer);
    if (byValue) {
      return byValue.value;
    }
    console.log('Pick one listed value.');
  }
};

const promptYesNo = async (rl, message, defaultValue) => {
  const suffix = defaultValue ? 'Y/n' : 'y/N';
  while (true) {
    const answer = (await rl.question(`${message} (${suffix}) `))
      .trim()
      .toLowerCase();
    if (!answer) {
      return defaultValue;
    }
    if (answer === 'y' || answer === 'yes') {
      return true;
    }
    if (answer === 'n' || answer === 'no') {
      return false;
    }
  }
};

const detectPackageManager = async (targetDir, pkg) => {
  const packageManager = pkg?.packageManager;
  if (typeof packageManager === 'string') {
    const manager = packageManager.split('@')[0];
    if (PACKAGE_MANAGERS[manager]) {
      return manager;
    }
  }

  for (const [manager, config] of Object.entries(PACKAGE_MANAGERS)) {
    if (await fileExists(path.join(targetDir, config.lockfile))) {
      return manager;
    }
  }

  if (pkg?.engines) {
    for (const manager of Object.keys(PACKAGE_MANAGERS)) {
      if (pkg.engines[manager]) {
        return manager;
      }
    }
  }

  return null;
};

const detectNodeMajor = (pkg) => {
  const engine = pkg?.engines?.node;
  if (typeof engine !== 'string') {
    return null;
  }
  const match = engine.match(/(?:>=|\^|~)?\s*(16|18|20|22|24)(?:\.|$)/);
  return match?.[1] ?? null;
};

const getPackageManagerVersion = (manager) =>
  commandVersion(manager, PACKAGE_MANAGERS[manager].defaultVersion);

const applyPackageManager = (pkg, selection, toolchainManager) => {
  if (selection === 'keep') {
    return;
  }

  const version = getPackageManagerVersion(toolchainManager);
  pkg.packageManager = `${toolchainManager}@${version}`;
  pkg.engines ??= {};
  pkg.engines[toolchainManager] = PACKAGE_MANAGERS[toolchainManager].engine;

  for (const manager of Object.keys(PACKAGE_MANAGERS)) {
    if (manager !== toolchainManager) {
      delete pkg.engines[manager];
    }
  }
};

const mergeObjectDefaults = (target, defaults, { overwrite = false } = {}) => {
  for (const [key, value] of Object.entries(defaults)) {
    if (overwrite || target[key] == null) {
      target[key] = value;
    }
  }
};

const applyPackageJson = async ({
  workspace,
  profile,
  profileName,
  packageManagerSelection,
  toolchainManager,
  nodeMajor,
  existingPackage,
  hasTsconfig,
}) => {
  const packagePath = workspace.targetPath('package.json');
  const creating = !existingPackage;
  const nodeConfig = NODE_TARGETS[nodeMajor];
  const pkg =
    existingPackage ??
    {
      name: sanitizePackageName(workspace.targetDir),
      version: '1.0.0',
      author: 'luke@lpdev.io',
      type: 'module',
      engines: {},
      scripts: {},
      devDependencies: {},
      license: 'AGPL-3.0-only',
    };

  pkg.engines ??= {};
  pkg.engines.node = nodeConfig.engine;
  applyPackageManager(pkg, packageManagerSelection, toolchainManager);

  if (creating && profileName !== 'config') {
    pkg.type ??= 'module';
  }

  pkg.scripts ??= {};
  mergeObjectDefaults(pkg.scripts, profile.scripts);

  if (profile.dependencies) {
    pkg.dependencies ??= {};
    mergeObjectDefaults(pkg.dependencies, profile.dependencies);
  }

  pkg.devDependencies ??= {};
  mergeObjectDefaults(pkg.devDependencies, profile.devDependencies);

  if (!creating && hasTsconfig) {
    mergeObjectDefaults(pkg.devDependencies, {
      '@types/node': TYPES_NODE_VERSION,
      typescript: TYPESCRIPT_VERSION,
    });
  }

  await workspace.write('package.json', `${JSON.stringify(pkg, null, 2)}\n`);
};

const renderFlake = ({
  projectName,
  nodeMajor,
  toolchainManager,
  extraPackages,
}) => {
  const nodeConfig = NODE_TARGETS[nodeMajor];
  const managerPackage = PACKAGE_MANAGERS[toolchainManager].packageFor(
    nodeConfig.nodePackage,
  );
  const packages = [
    `pkgs.${nodeConfig.nodePackage}`,
    managerPackage,
    ...extraPackages.map((pkg) => `pkgs.${pkg}`),
  ].filter(Boolean);
  const packageLines = packages.map((pkg) => `            ${pkg}`).join('\n');
  const oldNodeNote =
    nodeMajor === '16'
      ? '\n    # Node 16 is EOL/insecure and may require NIXPKGS_ALLOW_INSECURE=1.'
      : '';

  return `{
  description = "${projectName} local dev shell";

  inputs = {
    nixpkgs.url = "github:NixOS/nixpkgs/${nodeConfig.nixpkgs}";${oldNodeNote}
  };

  outputs = { self, nixpkgs }:
    let
      systems = [ "x86_64-linux" "aarch64-linux" "x86_64-darwin" "aarch64-darwin" ];
      forAllSystems = f: nixpkgs.lib.genAttrs systems (system: f {
        inherit system;
        pkgs = import nixpkgs { inherit system; };
      });
    in {
      devShells = forAllSystems ({ pkgs, ... }: {
        default = pkgs.mkShell {
          packages = [
${packageLines}
          ];

          shellHook = ''
            export PATH="$PWD/.flake.local/bin:$PATH"
          '';
        };
      });
    };
}
`;
};

const renderPnpmWorkspace = () => `allowBuilds:
  esbuild: true
`;

const renderTailwindPrettier = () => `const prettierConfig = {
  plugins: ['prettier-plugin-tailwindcss'],
  singleQuote: true,
  endOfLine: 'lf',
};

export default prettierConfig;
`;

const applyTsMode = async (workspace, mode) => {
  if (mode === 'preserve') {
    return;
  }

  const tsconfigPath = workspace.targetPath('tsconfig.json');
  if (!(await fileExists(tsconfigPath))) {
    return;
  }

  const tsconfig = await readJson(tsconfigPath);
  tsconfig.compilerOptions ??= {};
  Object.assign(
    tsconfig.compilerOptions,
    mode === 'non-strict' ? NON_STRICT_TS : STRICT_TS,
  );
  await workspace.write('tsconfig.json', `${JSON.stringify(tsconfig, null, 2)}\n`);
};

const copyStarter = async ({ workspace, templateRoot, profile, force }) => {
  if (!profile.starterDir) {
    return;
  }

  const root = path.join(templateRoot, 'starters', profile.starterDir);
  const walk = async (dir) => {
    const entries = await fsp.readdir(dir, { withFileTypes: true });
    for (const entry of entries) {
      const source = path.join(dir, entry.name);
      if (entry.isDirectory()) {
        await walk(source);
        continue;
      }
      const relativePath = path.relative(root, source);
      await workspace.write(relativePath, await readText(source), {
        overwrite: force,
      });
    }
  };

  await walk(root);
};

const applyCommonFiles = async ({
  workspace,
  templateRoot,
  toolchainManager,
  useTailwindPrettier,
}) => {
  await workspace.write(
    '.editorconfig',
    await readTemplate(templateRoot, 'common/.editorconfig'),
  );
  await workspace.write('.envrc', await readTemplate(templateRoot, 'common/.envrc'));

  const prettierConfigExists =
    (await fileExists(workspace.targetPath('prettier.config.mjs'))) ||
    (await fileExists(workspace.targetPath('prettier.config.js')));

  if (useTailwindPrettier) {
    await workspace.write('prettier.config.mjs', renderTailwindPrettier());
  } else if (!prettierConfigExists) {
    await workspace.write(
      '.prettierrc',
      await readTemplate(templateRoot, 'common/.prettierrc'),
    );
  } else {
    workspace.skipped.push('existing Prettier JS config kept');
  }

  const prettierIgnore = await readTemplate(templateRoot, 'common/.prettierignore');
  await workspace.mergeLines(
    '.prettierignore',
    prettierIgnore.split(/\r?\n/).filter((line) => line.trim()),
  );

  const gitignore = await readTemplate(templateRoot, 'common/.gitignore');
  await workspace.mergeLines(
    '.gitignore',
    gitignore.split(/\r?\n/).filter((line) => line.trim()),
  );
};

const runCommand = (command, args, cwd, dryRun) => {
  const display = [command, ...args].join(' ');
  if (dryRun) {
    console.log(`dry-run command: ${display}`);
    return;
  }
  const result = cp.spawnSync(command, args, {
    cwd,
    stdio: 'inherit',
  });
  if (result.error) {
    throw result.error;
  }
  if (result.status !== 0) {
    throw new Error(`Command failed (${result.status}): ${display}`);
  }
};

const commandExists = (command) => {
  const result = cp.spawnSync('sh', ['-c', `command -v ${command}`], {
    stdio: 'ignore',
  });
  return result.status === 0;
};

const markGitIntentToAdd = (targetDir, files, dryRun) => {
  if (
    cp.spawnSync('git', ['-C', targetDir, 'rev-parse', '--is-inside-work-tree'], {
      stdio: 'ignore',
    }).status !== 0
  ) {
    return;
  }

  const existing = files.filter((file) => fs.existsSync(path.join(targetDir, file)));
  if (existing.length === 0) {
    return;
  }

  if (dryRun) {
    console.log(`dry-run command: git add -N ${existing.join(' ')}`);
    return;
  }

  cp.spawnSync('git', ['-C', targetDir, 'add', '-N', '--', ...existing], {
    stdio: 'ignore',
  });
};

const resolveOptions = async ({ opts, targetDir, existingPackage }) => {
  const interactive = process.stdin.isTTY && process.stdout.isTTY && !opts.yes;
  const rl = interactive
    ? readline.createInterface({ input: process.stdin, output: process.stdout })
    : null;

  try {
    const hasPackage = Boolean(existingPackage);
    const detectedManager = await detectPackageManager(targetDir, existingPackage);
    const detectedNodeMajor = detectNodeMajor(existingPackage);

    const profileChoices = hasPackage
      ? [
          { label: 'config only', value: 'config' },
          { label: 'TypeScript Node', value: 'node' },
          { label: 'TypeScript Node + Vitest', value: 'node-vitest' },
          { label: 'Vite React', value: 'vite-react' },
        ]
      : [
          { label: 'TypeScript Node', value: 'node' },
          { label: 'TypeScript Node + Vitest', value: 'node-vitest' },
          { label: 'Vite React', value: 'vite-react' },
          { label: 'config only', value: 'config' },
        ];

    const profile =
      opts.profile ??
      (interactive
        ? await promptChoice(
            rl,
            hasPackage ? 'Existing package.json found. Apply which profile?' : 'Create which starter?',
            profileChoices,
            hasPackage ? 'config' : 'node',
          )
        : hasPackage
          ? 'config'
          : 'node');

    if (!PROFILES[profile]) {
      throw new Error(`Unknown profile: ${profile}`);
    }

    const packageManagerChoices = [
      { label: 'pnpm', value: 'pnpm' },
      { label: 'yarn classic', value: 'yarn' },
      { label: 'npm', value: 'npm' },
    ];
    if (hasPackage && detectedManager) {
      packageManagerChoices.push({
        label: `keep detected ${detectedManager}`,
        value: 'keep',
      });
    }

    const packageManager =
      opts.packageManager ??
      (interactive
        ? await promptChoice(
            rl,
            'Package manager?',
            packageManagerChoices,
            'pnpm',
          )
        : 'pnpm');

    if (
      packageManager !== 'keep' &&
      !Object.prototype.hasOwnProperty.call(PACKAGE_MANAGERS, packageManager)
    ) {
      throw new Error(`Unknown package manager: ${packageManager}`);
    }
    if (packageManager === 'keep' && !detectedManager) {
      throw new Error('Cannot keep package manager because none was detected');
    }

    const toolchainManager =
      packageManager === 'keep' ? detectedManager || 'pnpm' : packageManager;

    const nodeMajor =
      opts.nodeMajor ??
      (interactive
        ? await promptChoice(
            rl,
            'Node major for engines and flake?',
            Object.keys(NODE_TARGETS).map((value) => ({ label: value, value })),
            detectedNodeMajor || '24',
          )
        : detectedNodeMajor || '24');

    if (!NODE_TARGETS[nodeMajor]) {
      throw new Error(`Unsupported Node major: ${nodeMajor}`);
    }

    const tsMode =
      opts.tsMode ??
      (interactive
        ? await promptChoice(
            rl,
            'TypeScript strictness?',
            [
              { label: 'preserve existing', value: 'preserve' },
              { label: 'strict', value: 'strict' },
              { label: 'non-strict', value: 'non-strict' },
            ],
            hasPackage ? 'preserve' : 'strict',
          )
        : hasPackage
          ? 'preserve'
          : 'strict');

    const direnv =
      opts.direnv ??
      (interactive ? await promptYesNo(rl, 'Run direnv allow after writing files?', true) : true);
    const flakeLock =
      opts.flakeLock ??
      (interactive ? await promptYesNo(rl, 'Run nix flake lock after writing files?', true) : true);
    const install =
      opts.install ??
      (interactive
        ? await promptYesNo(rl, `Run ${toolchainManager} install after writing files?`, false)
        : false);

    return {
      profile,
      packageManager,
      toolchainManager,
      nodeMajor,
      tsMode,
      direnv,
      flakeLock,
      install,
    };
  } finally {
    rl?.close();
  }
};

const ensureTargetDir = async (targetDir, opts) => {
  const stat = await statOrNull(targetDir);
  if (stat && !stat.isDirectory()) {
    throw new Error(`Target exists but is not a directory: ${targetDir}`);
  }

  if (stat) {
    return;
  }

  const interactive = process.stdin.isTTY && process.stdout.isTTY && !opts.yes;
  if (interactive) {
    const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
    try {
      const create = await promptYesNo(rl, `Create ${targetDir}?`, true);
      if (!create) {
        throw new Error('Cancelled');
      }
    } finally {
      rl.close();
    }
  }

  if (!opts.dryRun) {
    await fsp.mkdir(targetDir, { recursive: true });
  }
};

const main = async () => {
  const argv = process.argv.slice(2);
  if (printRequestedHelp(argv)) {
    return;
  }

  const opts = parseArgs(argv);
  if (opts.help) {
    usage();
    return;
  }

  const targetDir = path.resolve(opts.dir ?? process.cwd());
  await ensureTargetDir(targetDir, opts);

  const templateRoot = await findTemplateRoot();
  const packagePath = path.join(targetDir, 'package.json');
  const existingPackage = (await fileExists(packagePath))
    ? await readJson(packagePath)
    : null;
  const resolved = await resolveOptions({ opts, targetDir, existingPackage });
  const profile = PROFILES[resolved.profile];
  const workspace = new Workspace({
    targetDir,
    dryRun: opts.dryRun,
    backup: opts.backup,
  });
  const hasTsconfigBefore = await fileExists(path.join(targetDir, 'tsconfig.json'));

  await copyStarter({
    workspace,
    templateRoot,
    profile,
    force: opts.force,
  });
  await applyCommonFiles({
    workspace,
    templateRoot,
    toolchainManager: resolved.toolchainManager,
    useTailwindPrettier: opts.tailwindPrettier,
  });
  await workspace.write(
    'flake.nix',
    renderFlake({
      projectName: existingPackage?.name || sanitizePackageName(targetDir),
      nodeMajor: resolved.nodeMajor,
      toolchainManager: resolved.toolchainManager,
      extraPackages: [],
    }),
  );

  if (resolved.toolchainManager === 'pnpm') {
    await workspace.write('pnpm-workspace.yaml', renderPnpmWorkspace(), {
      overwrite: false,
    });
  }

  const hasTsconfigAfter = await fileExists(path.join(targetDir, 'tsconfig.json'));
  await applyPackageJson({
    workspace,
    profile,
    profileName: resolved.profile,
    packageManagerSelection: resolved.packageManager,
    toolchainManager: resolved.toolchainManager,
    nodeMajor: resolved.nodeMajor,
    existingPackage,
    hasTsconfig: hasTsconfigBefore || hasTsconfigAfter || profile.needsTypescript,
  });
  if (
    resolved.tsMode !== 'preserve' &&
    (hasTsconfigBefore || resolved.tsMode === 'non-strict' || resolved.profile === 'config')
  ) {
    await applyTsMode(workspace, resolved.tsMode);
  }

  if (opts.gitAdd) {
    markGitIntentToAdd(
      targetDir,
      [
        '.envrc',
        'flake.nix',
        'flake.lock',
        '.prettierrc',
        'prettier.config.mjs',
        '.editorconfig',
        '.prettierignore',
        '.gitignore',
        'pnpm-workspace.yaml',
        'package.json',
        'tsconfig.json',
      ],
      opts.dryRun,
    );
  }

  if (resolved.direnv) {
    if (commandExists('direnv')) {
      runCommand('direnv', ['allow'], targetDir, opts.dryRun);
    } else {
      workspace.skipped.push('direnv not found');
    }
  }

  if (resolved.flakeLock) {
    if (commandExists('nix')) {
      runCommand('nix', ['flake', 'lock'], targetDir, opts.dryRun);
      if (opts.gitAdd) {
        markGitIntentToAdd(targetDir, ['flake.lock'], opts.dryRun);
      }
    } else {
      workspace.skipped.push('nix not found');
    }
  }

  if (resolved.install) {
    const installCommand = PACKAGE_MANAGERS[resolved.toolchainManager].installCommand;
    if (commandExists('nix') && (await fileExists(path.join(targetDir, 'flake.nix')))) {
      runCommand(
        'nix',
        ['develop', '--command', ...installCommand],
        targetDir,
        opts.dryRun,
      );
    } else {
      runCommand(installCommand[0], installCommand.slice(1), targetDir, opts.dryRun);
    }
  }

  console.log(`scaffold: ${targetDir}`);
  for (const line of workspace.changed) {
    console.log(`  ${line}`);
  }
  for (const line of workspace.skipped) {
    console.log(`  skipped: ${line}`);
  }
};

main().catch((error) => {
  console.error(`scaffold: ${error.message}`);
  process.exit(1);
});
