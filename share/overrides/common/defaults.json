{
  "version": 1,
  "description": "Common scaffold defaults applied to every project.",
  "actions": [
    {
      "type": "file.copyTemplate",
      "label": "Seed .editorconfig defaults",
      "path": ".editorconfig",
      "template": "shared/common/.editorconfig",
      "overwrite": false
    },
    {
      "type": "text.setProperties",
      "label": "Ensure .editorconfig defaults",
      "path": ".editorconfig",
      "create": true,
      "separator": " = ",
      "insertFinalNewline": true,
      "properties": {
        "root": "true",
        "indent_style": "space",
        "indent_size": "2",
        "tab_width": "2",
        "end_of_line": "lf",
        "charset": "utf-8",
        "trim_trailing_whitespace": "true",
        "insert_final_newline": "true"
      }
    },
    {
      "type": "file.copyTemplate",
      "label": "Seed .gitignore defaults",
      "path": ".gitignore",
      "template": "shared/common/.gitignore",
      "overwrite": false
    },
    {
      "type": "text.removeLines",
      "label": "Remove old assets ignores",
      "path": ".gitignore",
      "lines": ["assets/", "/assets/"]
    },
    {
      "type": "text.mergeLines",
      "label": "Merge default .gitignore entries",
      "path": ".gitignore",
      "existingHeader": "# generated with scaffold",
      "lines": [
        "node_modules",
        ".nuxt",
        ".output",
        ".next",
        "dist",
        "coverage",
        ".vite",
        "*.log",
        ".env",
        ".env.*",
        "!.env.example",
        ".flake.local/",
        ".direnv",
        ".DS_Store",
        "*.scaffold-backup",
        "*.scaffold-backup/"
      ]
    },
    {
      "type": "file.copyTemplate",
      "label": "Seed .prettierignore defaults",
      "path": ".prettierignore",
      "template": "shared/common/.prettierignore",
      "when": "prettier",
      "overwrite": false
    },
    {
      "type": "text.mergeLines",
      "label": "Merge default .prettierignore entries",
      "path": ".prettierignore",
      "when": "prettier",
      "lines": [
        "node_modules",
        ".nuxt",
        ".output",
        ".next",
        "dist",
        "coverage",
        ".vite",
        "*.log",
        ".env",
        ".env.*",
        "!.env.example",
        ".flake.local/",
        ".direnv",
        ".DS_Store",
        "pnpm-lock.yaml",
        "yarn.lock",
        "package-lock.json"
      ]
    },
    {
      "type": "group",
      "label": "Enable React Compiler in existing React Vite configs",
      "when": {
        "all": ["react", "vite"]
      },
      "actions": [
        {
          "type": "text.replace",
          "label": "Import React Compiler preset in TypeScript Vite config",
          "path": "vite.config.ts",
          "skipIfContains": "reactCompilerPreset",
          "regex": "import react from ['\"]@vitejs/plugin-react['\"];?",
          "replace": "import react, { reactCompilerPreset } from '@vitejs/plugin-react'"
        },
        {
          "type": "text.prepend",
          "label": "Import Babel plugin bridge in TypeScript Vite config",
          "path": "vite.config.ts",
          "create": false,
          "content": "import babel from '@rolldown/plugin-babel'\n",
          "skipIfContains": "@rolldown/plugin-babel"
        },
        {
          "type": "text.replace",
          "label": "Register React Compiler in TypeScript Vite config",
          "path": "vite.config.ts",
          "skipIfContains": "babel({ presets: [reactCompilerPreset()] })",
          "regex": "plugins:\\s*\\[react\\(\\)(.*)\\]",
          "replace": "plugins: [react(), babel({ presets: [reactCompilerPreset()] })$1]"
        },
        {
          "type": "text.replace",
          "label": "Import React Compiler preset in JavaScript Vite config",
          "path": "vite.config.js",
          "skipIfContains": "reactCompilerPreset",
          "regex": "import react from ['\"]@vitejs/plugin-react['\"];?",
          "replace": "import react, { reactCompilerPreset } from '@vitejs/plugin-react'"
        },
        {
          "type": "text.prepend",
          "label": "Import Babel plugin bridge in JavaScript Vite config",
          "path": "vite.config.js",
          "create": false,
          "content": "import babel from '@rolldown/plugin-babel'\n",
          "skipIfContains": "@rolldown/plugin-babel"
        },
        {
          "type": "text.replace",
          "label": "Register React Compiler in JavaScript Vite config",
          "path": "vite.config.js",
          "skipIfContains": "babel({ presets: [reactCompilerPreset()] })",
          "regex": "plugins:\\s*\\[react\\(\\)(.*)\\]",
          "replace": "plugins: [react(), babel({ presets: [reactCompilerPreset()] })$1]"
        },
        {
          "type": "text.replace",
          "label": "Import React Compiler preset in Vitest config",
          "path": "vitest.config.mts",
          "skipIfContains": "reactCompilerPreset",
          "regex": "import react from ['\"]@vitejs/plugin-react['\"];?",
          "replace": "import react, { reactCompilerPreset } from '@vitejs/plugin-react'"
        },
        {
          "type": "text.prepend",
          "label": "Import Babel plugin bridge in Vitest config",
          "path": "vitest.config.mts",
          "create": false,
          "content": "import babel from '@rolldown/plugin-babel';\n",
          "skipIfContains": "@rolldown/plugin-babel"
        },
        {
          "type": "text.replace",
          "label": "Register React Compiler in Vitest config",
          "path": "vitest.config.mts",
          "skipIfContains": "babel({ presets: [reactCompilerPreset()] })",
          "regex": "plugins:\\s*\\[react\\(\\)(.*)\\]",
          "replace": "plugins: [react(), babel({ presets: [reactCompilerPreset()] })$1]"
        }
      ]
    },
    {
      "type": "file.write",
      "label": "Write Prettier config with Tailwind plugin",
      "path": "prettier.config.mjs",
      "when": {
        "all": ["prettier", "tailwind"]
      },
      "content": "export default {\n  singleQuote: true,\n  plugins: ['prettier-plugin-tailwindcss'],\n};\n"
    },
    {
      "type": "file.write",
      "label": "Write Prettier config",
      "path": "prettier.config.mjs",
      "when": {
        "all": [
          "prettier",
          {
            "not": "tailwind"
          }
        ]
      },
      "content": "export default {\n  singleQuote: true,\n};\n"
    }
  ]
}
