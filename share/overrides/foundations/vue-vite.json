{
  "version": 1,
  "description": "Post-create-vue seeded foundation shape. Keeps useful Vue seed output and replaces the demo shell with a small Tailwind-ready app.",
  "actions": [
    {
      "type": "file.write",
      "label": "Replace seeded README with scaffold summary",
      "path": "README.md",
      "template": "seeded/README.md.tmpl"
    },
    {
      "type": "text.prepend",
      "label": "Import Tailwind Vite plugin in TypeScript Vite config",
      "path": "vite.config.ts",
      "when": {
        "all": ["tailwind", "typescript"]
      },
      "content": "import tailwindcss from '@tailwindcss/vite'\n",
      "skipIfContains": "@tailwindcss/vite"
    },
    {
      "type": "text.insertAfter",
      "label": "Enable native tsconfig path resolution in TypeScript Vite config",
      "path": "vite.config.ts",
      "when": "typescript",
      "match": "resolve: {\n",
      "content": "    tsconfigPaths: true,\n",
      "skipIfContains": "tsconfigPaths: true"
    },
    {
      "type": "text.insertAfter",
      "label": "Register Tailwind Vite plugin in TypeScript Vite config",
      "path": "vite.config.ts",
      "when": {
        "all": ["tailwind", "typescript"]
      },
      "skipIfContains": "tailwindcss()",
      "match": "plugins: [",
      "content": "\n    tailwindcss(),"
    },
    {
      "type": "text.prepend",
      "label": "Import Tailwind Vite plugin in JavaScript Vite config",
      "path": "vite.config.js",
      "when": {
        "all": [
          "tailwind",
          {
            "not": "typescript"
          }
        ]
      },
      "content": "import tailwindcss from '@tailwindcss/vite'\n",
      "skipIfContains": "@tailwindcss/vite"
    },
    {
      "type": "text.insertAfter",
      "label": "Register Tailwind Vite plugin in JavaScript Vite config",
      "path": "vite.config.js",
      "when": {
        "all": [
          "tailwind",
          {
            "not": "typescript"
          }
        ]
      },
      "skipIfContains": "tailwindcss()",
      "match": "plugins: [",
      "content": "\n    tailwindcss(),"
    },
    {
      "type": "file.write",
      "label": "Put Tailwind import in create-vue's imported CSS path",
      "path": "src/assets/base.css",
      "when": "tailwind",
      "template": "owned/vite/tailwind-vue.css"
    },
    {
      "type": "file.write",
      "label": "Put baseline reset in create-vue's imported CSS path",
      "path": "src/assets/base.css",
      "when": {
        "not": "tailwind"
      },
      "template": "owned/vite/reset.css"
    },
    {
      "type": "file.delete",
      "label": "Remove unused sidecar CSS paths",
      "paths": ["src/style.css", "src/assets/main.css"]
    },
    {
      "type": "dir.clean",
      "label": "Remove create-vue asset demo files while keeping base.css",
      "path": "src/assets",
      "keep": ["base.css"]
    },
    {
      "type": "text.replace",
      "label": "Import the scaffold CSS file from Vue entrypoint",
      "path": "src/main.ts",
      "when": {
        "all": ["typescript"]
      },
      "replacements": [
        {
          "match": "import './assets/main.css'",
          "replace": "import './assets/base.css'"
        },
        {
          "match": "import './style.css'",
          "replace": "import './assets/base.css'"
        }
      ]
    },
    {
      "type": "text.replace",
      "label": "Use aliases in TypeScript Vue entrypoint imports",
      "path": "src/main.ts",
      "when": "typescript",
      "replacements": [
        {
          "match": "import './assets/base.css'",
          "replace": "import '@/assets/base.css'"
        },
        {
          "match": "import './assets/main.css'",
          "replace": "import '@/assets/base.css'"
        },
        {
          "match": "import './style.css'",
          "replace": "import '@/assets/base.css'"
        },
        {
          "match": "import App from './App.vue'",
          "replace": "import App from '@/App.vue'"
        },
        {
          "match": "import router from './router'",
          "replace": "import router from '@/router'"
        }
      ]
    },
    {
      "type": "text.replace",
      "label": "Import the scaffold CSS file from Vue entrypoint",
      "path": "src/main.js",
      "when": {
        "all": [
          {
            "not": "typescript"
          }
        ]
      },
      "replacements": [
        {
          "match": "import './assets/main.css'",
          "replace": "import './assets/base.css'"
        },
        {
          "match": "import './style.css'",
          "replace": "import './assets/base.css'"
        }
      ]
    },
    {
      "type": "text.replace",
      "label": "Use aliases in Vue Router imports",
      "path": "src/router/index.ts",
      "when": {
        "all": ["router", "typescript"]
      },
      "replacements": [
        {
          "match": "import HomeView from '../views/HomeView.vue'",
          "replace": "import HomeView from '@/views/HomeView.vue'"
        },
        {
          "match": "import('../views/AboutView.vue')",
          "replace": "import('@/views/AboutView.vue')"
        }
      ]
    },
    {
      "type": "text.replace",
      "label": "Use aliases in Vue component test imports",
      "path": "src/components/__tests__/HelloWorld.spec.ts",
      "when": {
        "all": ["vitest", "vitestJsdom", "typescript"]
      },
      "replacements": [
        {
          "match": "import HelloWorld from '../HelloWorld.vue'",
          "replace": "import HelloWorld from '@/components/HelloWorld.vue'"
        }
      ]
    },
    {
      "type": "text.replace",
      "label": "Set Vue Vite document title",
      "path": "index.html",
      "regex": "<title>[^<]*</title>",
      "replace": "<title>Vue + Vite</title>"
    },
    {
      "type": "file.write",
      "label": "Replace create-vue router app shell",
      "path": "src/App.vue",
      "when": {
        "all": ["router", "tailwind"]
      },
      "template": "seeded/vue-vite/src/App.vue"
    },
    {
      "type": "file.write",
      "label": "Replace create-vue router app shell",
      "path": "src/App.vue",
      "when": {
        "all": [
          "router",
          {
            "not": "tailwind"
          }
        ]
      },
      "template": "seeded/vue-vite/src/App.plain.vue"
    },
    {
      "type": "file.write",
      "label": "Replace create-vue app shell",
      "path": "src/App.vue",
      "when": {
        "all": [
          {
            "not": "router"
          },
          "tailwind"
        ]
      },
      "template": "seeded/vue-vite/src/no-router/App.vue"
    },
    {
      "type": "file.write",
      "label": "Replace create-vue app shell",
      "path": "src/App.vue",
      "when": {
        "all": [
          {
            "not": "router"
          },
          {
            "not": "tailwind"
          }
        ]
      },
      "template": "seeded/vue-vite/src/no-router/App.plain.vue"
    },
    {
      "type": "file.write",
      "label": "Replace create-vue home route",
      "path": "src/views/HomeView.vue",
      "when": "router",
      "template": "seeded/vue-vite/src/views/HomeView.vue"
    },
    {
      "type": "file.write",
      "label": "Replace create-vue about route",
      "path": "src/views/AboutView.vue",
      "when": "router",
      "template": "seeded/vue-vite/src/views/AboutView.vue"
    },
    {
      "type": "dir.clean",
      "label": "Remove create-vue welcome/icon demo components",
      "path": "src/components",
      "keep": ["HelloWorld.vue", "__tests__/HelloWorld.spec.ts"]
    }
  ]
}
