{
  "version": 1,
  "description": "Post-create-next-app project shape.",
  "actions": [
    {
      "type": "file.write",
      "label": "Replace seeded README with scaffold summary",
      "path": "README.md",
      "template": "seeded/README.md.tmpl"
    },
    {
      "type": "json.merge",
      "label": "Add route-oriented TypeScript path aliases",
      "path": "tsconfig.json",
      "pointer": "/compilerOptions/paths",
      "when": "typescript",
      "create": false,
      "value": {
        "@/components/*": ["./src/app/_components/*"],
        "@/hooks/*": ["./src/app/_hooks/*"],
        "@/routes/*": ["./src/app/(routes)/*"],
        "@/styles/*": ["./src/app/_styles/*"],
        "@/types/*": ["./src/app/_types/*"],
        "@/utils/*": ["./src/app/_utils/*"],
        "@/sections/*": ["./src/app/_sections/*"],
        "@/*": ["./src/app/*"]
      }
    },
    {
      "type": "file.write",
      "label": "Keep route support directories in git",
      "path": "src/app/_components/.gitkeep",
      "when": "typescript",
      "content": "",
      "overwrite": false
    },
    {
      "type": "file.write",
      "label": "Keep route support directories in git",
      "path": "src/app/_hooks/.gitkeep",
      "when": "typescript",
      "content": "",
      "overwrite": false
    },
    {
      "type": "file.write",
      "label": "Keep route support directories in git",
      "path": "src/app/(routes)/.gitkeep",
      "when": "typescript",
      "content": "",
      "overwrite": false
    },
    {
      "type": "file.write",
      "label": "Keep route support directories in git",
      "path": "src/app/_styles/.gitkeep",
      "when": "typescript",
      "content": "",
      "overwrite": false
    },
    {
      "type": "file.write",
      "label": "Keep route support directories in git",
      "path": "src/app/_types/.gitkeep",
      "when": "typescript",
      "content": "",
      "overwrite": false
    },
    {
      "type": "file.write",
      "label": "Keep route support directories in git",
      "path": "src/app/_utils/.gitkeep",
      "when": "typescript",
      "content": "",
      "overwrite": false
    },
    {
      "type": "file.write",
      "label": "Keep route support directories in git",
      "path": "src/app/_sections/.gitkeep",
      "when": "typescript",
      "content": "",
      "overwrite": false
    },
    {
      "type": "file.write",
      "label": "Replace Next Tailwind CSS",
      "path": "src/app/_styles/globals.css",
      "when": "tailwind",
      "template": "seeded/next/app/_styles/globals.css"
    },
    {
      "type": "file.write",
      "label": "Replace Next CSS with baseline reset",
      "path": "src/app/_styles/globals.css",
      "when": {
        "not": "tailwind"
      },
      "template": "owned/vite/reset.css"
    },
    {
      "type": "file.delete",
      "label": "Remove create-next-app default CSS path",
      "paths": ["src/app/globals.css", "src/app/(routes)/.gitkeep", "src/app/_styles/.gitkeep"]
    },
    {
      "type": "file.write",
      "label": "Replace Next TypeScript layout",
      "path": "src/app/layout.tsx",
      "when": {
        "all": ["typescript", "tailwind"]
      },
      "template": "seeded/next/app/layout.tsx"
    },
    {
      "type": "file.write",
      "label": "Replace Next TypeScript layout",
      "path": "src/app/layout.tsx",
      "when": {
        "all": [
          "typescript",
          {
            "not": "tailwind"
          }
        ]
      },
      "template": "seeded/next/app/layout.plain.tsx"
    },
    {
      "type": "file.write",
      "label": "Replace Next JavaScript layout",
      "path": "src/app/layout.js",
      "when": {
        "all": [
          {
            "not": "typescript"
          },
          "tailwind"
        ]
      },
      "template": "seeded/next/app/layout.js"
    },
    {
      "type": "file.write",
      "label": "Replace Next JavaScript layout",
      "path": "src/app/layout.js",
      "when": {
        "all": [
          {
            "not": "typescript"
          },
          {
            "not": "tailwind"
          }
        ]
      },
      "template": "seeded/next/app/layout.plain.js"
    },
    {
      "type": "file.write",
      "label": "Replace Next TypeScript home route",
      "path": "src/app/page.tsx",
      "when": "typescript",
      "template": "seeded/next/app/page.tsx"
    },
    {
      "type": "file.write",
      "label": "Replace Next JavaScript home route",
      "path": "src/app/page.js",
      "when": {
        "not": "typescript"
      },
      "template": "seeded/next/app/page.js"
    },
    {
      "type": "file.write",
      "label": "Add Next TypeScript about route",
      "path": "src/app/(routes)/about/page.tsx",
      "when": "typescript",
      "template": "seeded/next/app/(routes)/about/page.tsx"
    },
    {
      "type": "file.write",
      "label": "Add Next JavaScript about route",
      "path": "src/app/(routes)/about/page.js",
      "when": {
        "not": "typescript"
      },
      "template": "seeded/next/app/(routes)/about/page.js"
    },
    {
      "type": "text.replace",
      "label": "Enable Next strict mode",
      "path": "next.config.ts",
      "skipIfContains": "reactStrictMode: true",
      "regex": "const nextConfig: NextConfig = \\{\\n",
      "replace": "const nextConfig: NextConfig = {\n  reactStrictMode: true,\n"
    },
    {
      "type": "text.replace",
      "label": "Enable Next strict mode",
      "path": "next.config.mjs",
      "skipIfContains": "reactStrictMode: true",
      "regex": "const nextConfig = \\{\\n",
      "replace": "const nextConfig = {\n  reactStrictMode: true,\n"
    },
    {
      "type": "text.removeLines",
      "label": "Remove placeholder Next config comment",
      "path": "next.config.ts",
      "lines": ["/* config options here */"]
    },
    {
      "type": "text.removeLines",
      "label": "Remove placeholder Next config comment",
      "path": "next.config.mjs",
      "lines": ["/* config options here */"]
    },
    {
      "type": "file.write",
      "label": "Add Next TypeScript Vitest config",
      "path": "vitest.config.mts",
      "when": {
        "all": ["vitest", "typescript"]
      },
      "content": "import react from '@vitejs/plugin-react';\nimport { defineConfig } from 'vitest/config';\nimport tsconfigPaths from 'vite-tsconfig-paths';\n\nexport default defineConfig({\n  plugins: [react(), tsconfigPaths()],\n  test: {\n    environment: 'node',\n    globals: true,\n    include: ['src/**/*.test.{ts,tsx}'],\n  },\n});\n"
    },
    {
      "type": "file.write",
      "label": "Add Next JavaScript Vitest config",
      "path": "vitest.config.mts",
      "when": {
        "all": [
          "vitest",
          {
            "not": "typescript"
          }
        ]
      },
      "content": "import react from '@vitejs/plugin-react';\nimport { defineConfig } from 'vitest/config';\n\nexport default defineConfig({\n  plugins: [react()],\n  test: {\n    environment: 'node',\n    globals: true,\n    include: ['src/**/*.test.{js,jsx}'],\n  },\n});\n"
    },
    {
      "type": "file.write",
      "label": "Add Next TypeScript sample test",
      "path": "src/app/page.test.tsx",
      "when": {
        "all": ["vitest", "typescript"]
      },
      "template": "seeded/next/tests/page.test.tsx"
    },
    {
      "type": "file.write",
      "label": "Add Next JavaScript sample test",
      "path": "src/app/page.test.jsx",
      "when": {
        "all": [
          "vitest",
          {
            "not": "typescript"
          }
        ]
      },
      "template": "seeded/next/tests/page.test.jsx"
    }
  ]
}
